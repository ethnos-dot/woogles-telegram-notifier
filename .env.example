# Copy to ".env" for local testing (the .env file is git-ignored).
# In GitHub Actions these are set as repository Secrets instead, not here.

WOOGLES_USERNAME=your_woogles_nickname

# Recommended auth: a personal API key.
# Get it at woogles.io -> Settings -> API -> generate, then paste it here.
# It's revocable (regenerate any time) and is NOT your password.
WOOGLES_API_KEY=your_woogles_api_key

# Optional fallback instead of the API key (less safe — stores your password):
# WOOGLES_PASSWORD=your_woogles_password

TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...
TELEGRAM_CHAT_ID=123456789
